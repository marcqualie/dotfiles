#compdef denvig

_denvig() {
  local -a completions
  local line

  # Get completions from denvig itself
  completions=("${(@f)$(denvig zsh __complete__ -- "${words[@]}" 2>/dev/null)}")

  if [[ ${#completions[@]} -gt 0 && -n "${completions[1]}" ]]; then
    _describe 'denvig' completions
  else
    _files
  fi
}

_denvig "$@"
